generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Sharing_Link {
  id         String   @id @default(uuid())
  code       String   @unique
  link       String   @db.Text
  identifier String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}

model Sharing_Doc {
  id         String   @id @default(uuid())
  code       String   @unique
  fileKey    String   @db.Text
  fileName   String
  fileType   String
  identifier String
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
